##########################
# M4A2 (USA_m4a2)
##########################
entity = {
	name = "USA_m4a2_entity"
	pdxmesh = "USA_m4a2_mesh"

	state = { name = "idle"				animation = "idle"   animation_blend_time = 0.3 animation_speed = 2.0 }
	state = { name = "move"				animation = "move"   animation_blend_time = 0.3 animation_speed = 2.0
		event = { time = 0 node ="left_exhaust" particle = "tank_exhaust_particle"  keep_particle = no trigger_once = yes }
		event = { time = 0 node ="right_exhaust" particle = "tank_exhaust_particle"  keep_particle = no trigger_once = yes }
		event = { time = 0 node ="left_tracks" particle = "tank_moving_tracks_particle"  keep_particle = no trigger_once = yes}
		event = { time = 0 node ="right_tracks" particle = "tank_moving_tracks_particle"  keep_particle = no trigger_once = yes}
		event = { trigger_once = yes sound = { soundeffect = "tank_engine_medium_move" } }
	}
	state = { name = "retreat"				animation = "move"   animation_blend_time = 0.3 animation_speed = 2.0
		event = { time = 0 node ="left_exhaust" particle = "tank_exhaust_particle"  keep_particle = no trigger_once = yes }
		event = { time = 0 node ="right_exhaust" particle = "tank_exhaust_particle"  keep_particle = no trigger_once = yes }
		event = { time = 0 node ="left_tracks" particle = "tank_moving_tracks_particle"  keep_particle = no trigger_once = yes}
		event = { time = 0 node ="right_tracks" particle = "tank_moving_tracks_particle"  keep_particle = no trigger_once = yes}
		event = { trigger_once = yes sound = { soundeffect = "tank_engine_medium_move" } }
	}
	state = { name = "attack"			animation = "attack" animation_blend_time = 0.3 animation_speed = 2.0
		event = { time = 0 node ="barrel" particle = "heavy_tank_attack_barrel_particle"  keep_particle = yes light = "muzzle_flash" sound = { soundeffect = medium_armour_fire } }
		event = { time = 0 node ="barrel" particle = "heavy_tank_attack_barrel_smoke_particle"  keep_particle = yes light = "muzzle_flash" sound = { soundeffect = heavy_armour_fire }}
	}
	state = { name = "defend"			animation = "attack" animation_blend_time = 0.3 animation_speed = 2.0
		event = { time = 0 node ="barrel" particle = "heavy_tank_attack_barrel_particle"  keep_particle = yes light = "muzzle_flash" sound = { soundeffect = medium_armour_fire } }
		event = { time = 0 node ="barrel" particle = "heavy_tank_attack_barrel_smoke_particle"  keep_particle = yes light = "muzzle_flash" sound = { soundeffect = heavy_armour_fire }}
	}
	state = { name = "support_attack"	animation = "attack" animation_blend_time = 0.3 animation_speed = 2.0
		event = { time = 0 node ="barrel" particle = "heavy_tank_attack_barrel_particle"  keep_particle = yes light = "muzzle_flash" sound = { soundeffect = medium_armour_fire } }
		event = { time = 0 node ="barrel" particle = "heavy_tank_attack_barrel_smoke_particle"  keep_particle = yes light = "muzzle_flash" sound = { soundeffect = heavy_armour_fire }}
	}
	state = { name = "training"				animation = "idle" 			animation_blend_time = 0.3  animation_speed = 2.0
		event = { time = 0 node ="left_exhaust" particle = "tank_exhaust_particle"  keep_particle = no trigger_once = yes }
		event = { time = 0 node ="right_exhaust" particle = "tank_exhaust_particle"  keep_particle = no trigger_once = yes }
	}

	scale = 0.6

	game_data = {
		texture_anim_speed = 0.5
